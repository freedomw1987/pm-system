# ============================================================
# PM-System 客戶部署 .env template
# 客戶要 copy 呢個 file 做 .env,然後改下面 3 個 ⚠️ 必填
# 其他可以保留 default
#
# install.sh 會 check 邊個 field 仲係 placeholder
# ============================================================

# ── ⚠️ 必填:發佈版本(同你收嘅 tarball 名對應)──────────
VERSION=v1.0.0

# ── ⚠️ 必填:Database password ───────────────────────────
# ⚠️ 必須改!用強密碼,例: openssl rand -hex 24
DB_PASSWORD=PLACEHOLDER_DB_PASSWORD
# ── Database 帳號/名(可以保留 default)─────────────────
DB_USER=pmuser
DB_NAME=pmdb

# ── ⚠️ 必填:JWT 密鑰 ──────────────────────────────────
# 用呢條命令生成:
#   openssl rand -hex 32
# 然後 paste 落下面
JWT_SECRET=PLACEHOLDER_JWT_SECRET
# ── 可選:Frontend URL(用嚟 CORS / email link)─────────
# 客戶機用 http://server-ip 直接訪問 → 保留 http://localhost
# 如果擺 domain → 改做 https://pm.example.com
FRONTEND_URL=http://localhost

# ── 可選:Frontend host port(預設 80)──────────────────
# 如果 80 已被用,可以改做 8080 / 8888 等
FRONTEND_HOST_PORT=80
