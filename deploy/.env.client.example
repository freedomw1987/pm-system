# ============================================================
# PM-System 客戶部署 .env template
# 客戶要 copy 呢個 file 做 .env,然後改下面 3 個 ⚠️ 必填
# 其他可以保留 default
#
# install.sh 會 check 邊個 field 仲係 placeholder
# ============================================================

# ── ⚠️ 必填:發佈版本(同你收嘅 tarball 名對應)──────────
VERSION=v1.0.0

# ── ⚠️ 必填:Database password ───────────────────────────
# ⚠️ 必須改!用強密碼,例: openssl rand -hex 24
DB_PASSWORD=PLACEHOLDER_DB_PASSWORD
# ── Database 帳號/名(可以保留 default)─────────────────
DB_USER=pmuser
DB_NAME=pmdb

# ── ⚠️ 必填:JWT 密鑰 ──────────────────────────────────
# 用呢條命令生成:
#   openssl rand -hex 32
# 然後 paste 落下面
JWT_SECRET=PLACEHOLDER_JWT_SECRET
# ── 可選:Frontend URL(用嚟 CORS / email link)─────────
# 客戶機用 http://server-ip 直接訪問 → 保留 http://localhost
# 如果擺 domain → 改做 https://pm.example.com
FRONTEND_URL=http://localhost

# ── 可選:Frontend host port(預設 80)──────────────────
# 如果 80 已被用 / 唔識 bind privileged port
# 可以改做 8080 / 8888 等。container 內部仍然行 80。
FRONTEND_HOST_PORT=80

# ── 可選:Frontend HTTPS host port(預設 443)───────────
# 80 收到嘅 request 會自動 301 → 呢個 port
# 如果 443 已被用 / 唔識 bind,可以改做 8443 等。
# 注意:用非標準 port 時,HTTP-01 certbot 唔可用,
# 要用 DNS-01 challenge(見 README)。
FRONTEND_HTTPS_HOST_PORT=443

# ── 可選:TLS cert 額外 SAN ─────────────────────────────
# gen-cert.sh 自動偵測本機 IP 寫入 cert。
# 如果 server 有多個 IP / 客戶有 domain,加落呢度:
#   EXTRA_SAN_IP="10.0.0.5 203.0.113.10"
#   EXTRA_SAN_DNS="pm.example.com"
EXTRA_SAN_IP=
EXTRA_SAN_DNS=

# ── 可選:TLS cert 有效日數(預設 825)──────────────────
# 825 = 瀏覽器對自簽 cert 接受嘅上限(2026 年起)
# (自簽先用呢個,Let's Encrypt 嘅 cert 由 certbot 控制,~90 日)
CERT_DAYS=825

# ── 可選:用 Let's Encrypt(推薦用真 domain 嘅時候)───
# 設咗 DOMAIN + /etc/letsencrypt/live/$DOMAIN/ 有 fullchain.pem/privkey.pem
# install.sh / regen-cert.sh 會自動用呢個,跳過自簽。
#
# setup 步驟:
#   1. sudo apt install certbot
#   2. sudo certbot certonly --standalone -d pm.david-developer.com
#      (需要 port 80 暫時 free — 先 docker compose down,簽完再 up)
#   3. 設下面呢行:
DOMAIN=

# ── 可選:LLM call timeout(預設 180000ms = 3 分鐘)──
# 用嚟打 LLM API 嘅 AbortSignal timeout。
# 設短咗會喺 LLM 仲未返之前 abort,前端見到 0 chunk / generic error。
#
# 點解唔係 60s?PROD 客戶機網速慢,PDF 上傳走 base64 PNG image
# (50MB PDF × 多頁可能 10-30MB 嘅 base64),上傳 + LLM OCR 喺
# 慢網情況下隨時 60-120s。3 分鐘提供 1.5x buffer。
#
# 上限:frontend nginx proxy_read_timeout 600s,超過會撞 silent fail
# (browser fetch 見 "upstream prematurely closed",backend 寫唔切
#  response tail marker)。想調高到 300-500s 都仲安全。
#
# 影響範圍:backend/src/routes/documents.ts 嘅 wiki 上傳路徑。
# chat 路由有自己嘅 120s timeout(backend/src/routes/chat.ts),唔受呢個影響。
LLM_TIMEOUT_MS=180000
